---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const locale = 'ja';
const t = useTranslations(locale);
const currentPath = '/contact';
const FORMSPREE_ID = 'YOUR_FORMSPREE_ID';
---

<BaseLayout locale={locale} t={t} title={t.contact.heading} currentPath={currentPath}>

  <section class="py-16 bg-warmwhite border-b border-border">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-xs text-shu font-semibold tracking-widest uppercase mb-3">Contact</p>
      <h1 class="text-3xl md:text-4xl font-bold text-charcoal">{t.contact.heading}</h1>
      <p class="text-midgray mt-3 text-sm">{t.contact.subheading}</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-xl mx-auto px-4 sm:px-6">
      <form id="contact-form" action={`https://formspree.io/f/${FORMSPREE_ID}`} method="POST" class="space-y-5">

        <div>
          <label for="name" class="block text-xs font-semibold text-charcoal mb-1.5 uppercase tracking-wider">
            {t.contact.form.name} <span class="text-shu">*</span>
          </label>
          <input type="text" id="name" name="name" required placeholder={t.contact.form.namePlaceholder}
            class="w-full px-4 py-3 bg-warmwhite border border-border text-sm text-charcoal rounded-sm
                   focus:outline-none focus:border-shu focus:bg-white transition-colors" />
        </div>

        <div>
          <label for="email" class="block text-xs font-semibold text-charcoal mb-1.5 uppercase tracking-wider">
            {t.contact.form.email} <span class="text-shu">*</span>
          </label>
          <input type="email" id="email" name="email" required placeholder={t.contact.form.emailPlaceholder}
            class="w-full px-4 py-3 bg-warmwhite border border-border text-sm text-charcoal rounded-sm
                   focus:outline-none focus:border-shu focus:bg-white transition-colors" />
        </div>

        <div>
          <label for="native-language" class="block text-xs font-semibold text-charcoal mb-1.5 uppercase tracking-wider">
            {t.contact.form.nativeLanguage}
          </label>
          <input type="text" id="native-language" name="native_language" placeholder={t.contact.form.nativeLanguagePlaceholder}
            class="w-full px-4 py-3 bg-warmwhite border border-border text-sm text-charcoal rounded-sm
                   focus:outline-none focus:border-shu focus:bg-white transition-colors" />
        </div>

        <div>
          <label for="course" class="block text-xs font-semibold text-charcoal mb-1.5 uppercase tracking-wider">
            {t.contact.form.courseInterest}
          </label>
          <select id="course" name="course_interest"
            class="w-full px-4 py-3 bg-warmwhite border border-border text-sm text-charcoal rounded-sm
                   focus:outline-none focus:border-shu focus:bg-white transition-colors">
            <option value="">— 選択してください —</option>
            {t.contact.form.courseOptions.map((opt: string) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="block text-xs font-semibold text-charcoal mb-1.5 uppercase tracking-wider">
            {t.contact.form.message} <span class="text-shu">*</span>
          </label>
          <textarea id="message" name="message" required rows={5} placeholder={t.contact.form.messagePlaceholder}
            class="w-full px-4 py-3 bg-warmwhite border border-border text-sm text-charcoal rounded-sm
                   focus:outline-none focus:border-shu focus:bg-white transition-colors resize-none"></textarea>
        </div>

        <div class="flex items-center gap-3 py-3 px-4 bg-warmwhite border border-border rounded-sm">
          <input type="checkbox" id="trial" name="trial_lesson" value="yes" class="w-4 h-4 accent-shu cursor-pointer" />
          <label for="trial" class="text-sm text-charcoal cursor-pointer">{t.contact.form.trialLesson}</label>
        </div>

        <button type="submit" id="submit-btn" class="w-full btn-primary py-4 tracking-widest">
          {t.contact.form.submit}
        </button>
      </form>

      <!-- 成功 -->
      <div id="success-message" class="hidden text-center py-12">
        <div class="w-16 h-16 rounded-full bg-redlight flex items-center justify-center mx-auto mb-4">
          <span class="text-shu text-2xl font-bold">月</span>
        </div>
        <h2 class="text-xl font-bold text-charcoal mb-2">{t.contact.form.successTitle}</h2>
        <p class="text-sm text-midgray">{t.contact.form.successMessage}</p>
      </div>

      <!-- エラー -->
      <div id="error-message" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-sm">
        <p class="text-sm text-shu">{t.contact.form.errorMessage}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-message');
  const errorMsg   = document.getElementById('error-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = '送信中...';
    errorMsg?.classList.add('hidden');
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) { form.classList.add('hidden'); successMsg?.classList.remove('hidden'); }
      else throw new Error();
    } catch {
      errorMsg?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = '送信する';
    }
  });
</script>
