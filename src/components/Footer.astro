---
import { getLocalePath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  t: Record<string, any>;
}
const { locale, t } = Astro.props;
---

<footer class="bg-white border-t border-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- ブランド -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="w-6 h-6 rounded-full bg-shu flex-shrink-0" aria-hidden="true"></span>
          <span class="text-lg font-bold text-charcoal">{t.site.name}</span>
        </div>
        <p class="text-sm text-midgray leading-relaxed max-w-xs">{t.footer.tagline}</p>
      </div>

      <!-- ナビ -->
      <div>
        <h3 class="text-xs font-semibold text-charcoal mb-3 uppercase tracking-widest">{t.footer.links}</h3>
        <ul class="space-y-2">
          {[
            { href: getLocalePath(locale),             label: t.nav.home },
            { href: getLocalePath(locale, '/about'),   label: t.nav.about },
            { href: getLocalePath(locale, '/courses'), label: t.nav.courses },
            { href: getLocalePath(locale, '/contact'), label: t.nav.contact },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-midgray hover:text-shu transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="mt-10 pt-6 border-t border-border text-center">
      <p class="text-xs text-midgray">{t.footer.copyright}</p>
    </div>
  </div>
</footer>
