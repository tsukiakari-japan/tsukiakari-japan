---
import { getLocalePath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  t: Record<string, any>;
}
const { locale, t } = Astro.props;
---

<section class="relative min-h-[88vh] flex items-center overflow-hidden bg-warmwhite">

  <!-- 右側：薄い朱色同心円（和のモチーフ） -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/3 w-[480px] h-[480px] md:w-[640px] md:h-[640px] rounded-full bg-shu/8 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-[320px] h-[320px] md:w-[440px] md:h-[440px] rounded-full bg-shu/12 pointer-events-none" aria-hidden="true"></div>

  <!-- 薄いグリッドパターン -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#1C1C1C" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

      <!-- 左カラム：キャッチコピー・CTA -->
      <div>

        <!-- 朱線 + 英語キャプション -->
        <div class="flex items-center gap-3 mb-8">
          <span class="w-8 h-px bg-shu" aria-hidden="true"></span>
          <span class="text-shu text-xs font-semibold tracking-[0.2em] uppercase">
            Japanese Language School
          </span>
        </div>

        <!-- キャッチコピー -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-charcoal leading-[1.2] mb-7 tracking-tight">
          {t.hero.headline}
        </h1>

        <!-- サブテキスト -->
        <p class="text-base md:text-lg text-midgray leading-relaxed mb-10 max-w-md">
          {t.hero.subtext}
        </p>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={getLocalePath(locale, '/contact')} class="btn-primary text-center">
            {t.hero.cta}
          </a>
          <a href={getLocalePath(locale, '/courses')} class="btn-outline text-center">
            {t.nav.courses}
          </a>
        </div>

        <p class="mt-5 text-sm text-midgray/60">{t.hero.ctaSub}</p>
      </div>

      <!-- 右カラム：教室の写真 -->
      <div class="order-last">
        <img
          src="/classroom.jpg"
          alt="つきあかり日本語教室の授業風景"
          class="w-full rounded-2xl shadow-2xl object-cover aspect-[4/3]"
        />
      </div>

    </div>
  </div>

  <!-- スクロール示唆 -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-midgray/40" aria-hidden="true">
    <span class="text-[10px] tracking-widest uppercase">Scroll</span>
    <span class="w-px h-8 bg-current"></span>
  </div>
</section>
