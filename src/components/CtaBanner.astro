---
import { getLocalePath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  t: Record<string, any>;
}
const { locale, t } = Astro.props;
---

<section class="py-20 bg-shu relative overflow-hidden">
  <!-- 装飾円 -->
  <div class="absolute -right-16 top-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-white/5 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -left-8  top-1/2 -translate-y-1/2 w-40 h-40 rounded-full bg-white/5 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <p class="text-white/70 text-xs tracking-widest uppercase mb-4">Trial Lesson</p>
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">{t.hero.cta}</h2>
    <p class="text-white/80 mb-8 text-[15px]">{t.hero.ctaSub}</p>
    <a
      href={getLocalePath(locale, '/contact')}
      class="inline-block bg-white text-shu font-bold px-10 py-4 rounded-sm
             hover:bg-warmwhite transition-colors duration-200 tracking-wide"
    >
      {t.hero.cta}
    </a>
  </div>
</section>
